<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
  <meta name="description" content="<%= product.name %> - Daphné" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="product-detail-page">
      <div class="container product-detail-layout-v2">
        <div class="product-gallery-v2">
          <div class="product-main-image-v2">
            <img
              id="mainProductImage"
              src="<%= product.images?.[0]?.image_url || '/images/hero-placeholder.jpg' %>"
              alt="<%= product.name %>"
            >
          </div>

          <% if (product.images && product.images.length > 1) { %>
            <div class="product-thumbs-v2">
              <% product.images.forEach((image) => { %>
                <button
                  type="button"
                  class="thumb-btn thumb-btn-v2"
                  data-image="<%= image.image_url %>"
                >
                  <img src="<%= image.image_url %>" alt="<%= image.alt_text || product.name %>">
                </button>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="product-info-v2">
          <span class="product-badge <%= product.status %>">
            <%= product.status === 'sale' ? 'SALE' : product.status === 'sold_out' ? 'AGOTADO' : 'EN STOCK' %>
          </span>

          <span class="product-category-v3"><%= product.category %></span>
          <h1><%= product.name %></h1>
          <p class="price big"><%= formatCurrency(product.price) %></p>

          <p class="product-description-v2"><%= product.description %></p>

          <div class="product-meta-v2">
            <% if (product.variants && product.variants.length) { %>
              <div class="product-meta-block">
                <strong>Variantes disponibles</strong>
                <div class="meta-pills">
                  <% product.variants.forEach((variant) => { %>
                    <span class="meta-pill">
                      <%= variant.color_name %> · <%= variant.size_name %> · <%= variant.stock %>u
                    </span>
                  <% }) %>
                </div>
              </div>
            <% } %>
          </div>

          <form action="/carrito/agregar" method="POST" class="product-buy-form-v2" id="productBuyForm">
            <input type="hidden" name="productId" value="<%= product.id %>">
            <input type="hidden" name="variantId" id="variantIdInput" value="">

            <%
              const availableColors = [...new Set((product.variants || []).map(v => v.color_name))];
              const availableSizes = [...new Set((product.variants || []).map(v => v.size_name))];
            %>

            <% if (availableColors.length) { %>
              <div class="form-row-v2">
                <label>Color</label>
                <div class="selector-pills" id="colorSelector">
                  <% availableColors.forEach((color, index) => { %>
                    <button
                      type="button"
                      class="selector-pill selector-pill-color <%= index === 0 ? 'active' : '' %>"
                      data-color="<%= color %>"
                    >
                      <%= color %>
                    </button>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <% if (availableSizes.length) { %>
              <div class="form-row-v2">
                <label>Talle</label>
                <div class="selector-pills" id="sizeSelector">
                  <% availableSizes.forEach((size, index) => { %>
                    <button
                      type="button"
                      class="selector-pill selector-pill-size <%= index === 0 ? 'active' : '' %>"
                      data-size="<%= size %>"
                    >
                      <%= size %>
                    </button>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <div class="form-row-v2">
              <label>Variante elegida</label>
              <div class="selected-variant-box" id="selectedVariantBox">
                Seleccioná color y talle
              </div>
            </div>

            <div class="form-row-v2">
              <label for="quantity">Cantidad</label>
              <input id="quantity" type="number" name="quantity" min="1" value="1" required>
            </div>

            <div class="product-detail-actions-v2">
              <button class="btn btn-primary" type="submit" id="addToCartBtn">Agregar al carrito</button>

              <a
                class="btn btn-secondary"
                target="_blank"
                rel="noopener noreferrer"
                href="https://wa.me/<%= site?.whatsapp || '' %>?text=<%= encodeURIComponent(`Hola, quiero consultar por el producto: ${product.name}`) %>"
              >
                Consultar por WhatsApp
              </a>
            </div>

            <script>
              window.productVariants = <%- JSON.stringify(product.variants || []) %>;
            </script>
          </form>

          <% if (product.size_chart_html) { %>
            <div class="size-chart-box-v2">
              <h3>Tabla de talles</h3>
              <div class="size-chart-html-v2">
                <%- product.size_chart_html %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>

  <script>
    (function () {
      const variants = Array.isArray(window.productVariants) ? window.productVariants : [];
      const form = document.getElementById('productBuyForm');
      const colorButtons = Array.from(document.querySelectorAll('.selector-pill-color'));
      const sizeButtons = Array.from(document.querySelectorAll('.selector-pill-size'));
      const variantInput = document.getElementById('variantIdInput');
      const selectedVariantBox = document.getElementById('selectedVariantBox');
      const quantityInput = document.getElementById('quantity');
      const addToCartBtn = document.getElementById('addToCartBtn');

      let selectedColor = colorButtons.find(btn => btn.classList.contains('active'))?.dataset.color || null;
      let selectedSize = sizeButtons.find(btn => btn.classList.contains('active'))?.dataset.size || null;

      function findVariant() {
        return variants.find((variant) => {
          return variant.color_name === selectedColor && variant.size_name === selectedSize;
        });
      }

      function setActiveButton(buttons, activeValue, key) {
        buttons.forEach((btn) => {
          const isActive = btn.dataset[key] === activeValue;
          btn.classList.toggle('active', isActive);
        });
      }

      function refreshVariantState() {
        const variant = findVariant();

        if (!variant) {
          variantInput.value = '';
          selectedVariantBox.textContent = 'Combinación no disponible';
          quantityInput.value = 1;
          quantityInput.min = 1;
          quantityInput.max = 1;
          quantityInput.disabled = true;
          addToCartBtn.disabled = true;
          addToCartBtn.textContent = 'Variante no disponible';
          addToCartBtn.style.opacity = '0.6';
          addToCartBtn.style.cursor = 'not-allowed';
          return;
        }

        variantInput.value = variant.id;

        const stock = Number(variant.stock || 0);

        if (stock <= 0) {
          selectedVariantBox.textContent = `${variant.color_name} · ${variant.size_name} · Sin stock`;
          quantityInput.value = 1;
          quantityInput.min = 1;
          quantityInput.max = 1;
          quantityInput.disabled = true;
          addToCartBtn.disabled = true;
          addToCartBtn.textContent = 'Sin stock';
          addToCartBtn.style.opacity = '0.6';
          addToCartBtn.style.cursor = 'not-allowed';
          return;
        }

        selectedVariantBox.textContent = `${variant.color_name} · ${variant.size_name} · Stock: ${stock}`;

        quantityInput.disabled = false;
        quantityInput.min = 1;
        quantityInput.max = stock;

        let currentQty = Number(quantityInput.value || 1);
        if (!Number.isInteger(currentQty) || currentQty < 1) currentQty = 1;
        if (currentQty > stock) currentQty = stock;
        quantityInput.value = currentQty;

        addToCartBtn.disabled = false;
        addToCartBtn.textContent = 'Agregar al carrito';
        addToCartBtn.style.opacity = '1';
        addToCartBtn.style.cursor = 'pointer';
      }

      colorButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          selectedColor = btn.dataset.color;
          setActiveButton(colorButtons, selectedColor, 'color');
          refreshVariantState();
        });
      });

      sizeButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          selectedSize = btn.dataset.size;
          setActiveButton(sizeButtons, selectedSize, 'size');
          refreshVariantState();
        });
      });

      quantityInput.addEventListener('input', () => {
        const variant = findVariant();
        if (!variant) return;

        const stock = Number(variant.stock || 0);
        let value = Number(quantityInput.value || 1);

        if (!Number.isInteger(value) || value < 1) {
          value = 1;
        }

        if (value > stock) {
          value = stock;
        }

        quantityInput.value = value;
      });

      form.addEventListener('submit', (event) => {
        const variant = findVariant();

        if (!variant) {
          event.preventDefault();
          selectedVariantBox.textContent = 'Seleccioná una variante válida';
          return;
        }

        const stock = Number(variant.stock || 0);
        const qty = Number(quantityInput.value || 1);

        if (!Number.isInteger(qty) || qty < 1) {
          event.preventDefault();
          quantityInput.value = 1;
          return;
        }

        if (stock <= 0) {
          event.preventDefault();
          selectedVariantBox.textContent = `${variant.color_name} · ${variant.size_name} · Sin stock`;
          return;
        }

        if (qty > stock) {
          event.preventDefault();
          quantityInput.value = stock;
          selectedVariantBox.textContent = `${variant.color_name} · ${variant.size_name} · Stock máximo: ${stock}`;
          return;
        }

        variantInput.value = variant.id;
      });

      refreshVariantState();

      const thumbButtons = Array.from(document.querySelectorAll('.thumb-btn-v2'));
      const mainImage = document.getElementById('mainProductImage');

      thumbButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const newImage = button.dataset.image;
          if (newImage && mainImage) {
            mainImage.src = newImage;
          }
        });
      });
    })();
  </script>
</body>
</html>