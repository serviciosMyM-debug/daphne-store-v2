<!DOCTYPE html>
<html lang="es">
<head>
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <%- include('partials/header') %>

  <section class="auth-section">
    <div class="auth-card">
      <span class="eyebrow">Panel privado</span>
      <h1>Ingreso administrador</h1>

      <% if (error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login" class="auth-form">
        <label for="email">Email</label>
        <input id="email" type="email" name="email" required>

        <label for="password">Contraseña</label>
        <input id="password" type="password" name="password" required>

        <button type="submit" class="btn btn-primary btn-full">Ingresar</button>
      </form>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>