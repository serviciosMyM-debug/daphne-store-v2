<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
  <meta name="description" content="Panel administrador Daphné" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="saas-body">
  <main class="saas-form-page">
    <div class="saas-form-top">
      <div>
        <span class="saas-eyebrow">Gestión de catálogo</span>
        <h1><%= product && product.id ? 'Editar producto' : 'Nuevo producto' %></h1>
      </div>

      <div class="saas-top-actions">
        <a href="/admin" class="saas-btn saas-btn-outline">Volver al dashboard</a>
      </div>
    </div>

    <form
      action="<%= product && product.id ? '/admin/productos/' + product.id + '?_method=PUT' : '/admin/productos' %>"
      method="POST"
      enctype="multipart/form-data"
      class="saas-product-form"
    >
      <div class="saas-form-grid">
        <section class="saas-card saas-form-section">
          <h2>Información principal</h2>

          <label for="name">Nombre del producto</label>
          <input
            id="name"
            type="text"
            name="name"
            required
            value="<%= product?.name || '' %>"
          >

          <label for="description">Descripción</label>
          <textarea
            id="description"
            name="description"
            rows="6"
            required
          ><%= product?.description || '' %></textarea>

          <label for="category">Categoría</label>
          <input
            id="category"
            type="text"
            name="category"
            value="<%= product?.category || '' %>"
          >

          <label for="price">Precio</label>
          <input
            id="price"
            type="number"
            step="0.01"
            min="0"
            name="price"
            required
            value="<%= product?.price || '' %>"
          >

          <label for="size_chart_html">Tabla de talles / HTML opcional</label>
          <textarea
            id="size_chart_html"
            name="size_chart_html"
            rows="5"
            placeholder="Ejemplo: S: 40,5 cm ancho / 42 cm largo"
          ><%= product?.size_chart_html || '' %></textarea>
        </section>

        <section class="saas-card saas-form-section">
          <h2>Stock y visibilidad</h2>

          <label for="stock_preview">Stock total calculado</label>
          <input
            id="stock_preview"
            type="text"
            value="<%= product?.stock || 0 %>"
            readonly
          >

          <label for="status">Estado visual</label>
          <select id="status" name="status">
            <option value="in_stock" <%= product?.status === 'in_stock' ? 'selected' : '' %>>En stock</option>
            <option value="sold_out" <%= product?.status === 'sold_out' ? 'selected' : '' %>>Agotado</option>
            <option value="hidden" <%= product?.status === 'hidden' ? 'selected' : '' %>>Oculto</option>
          </select>

          <label for="variants_text">Variantes (una por línea)</label>
          <textarea
            id="variants_text"
            name="variants_text"
            rows="10"
            required
            placeholder="Blanco|S|2&#10;Blanco|M|3&#10;Negro|L|1"
          ><%= product?.variantsText || '' %></textarea>

          <div style="margin-top: 6px; color: #64748b; line-height: 1.7; font-size: 0.95rem;">
            <strong style="color:#0d1b2a;">Formato:</strong> Color|Talle|Stock
            <br>
            Ejemplo:
            <br>
            Blanco|S|2
            <br>
            Blanco|M|3
            <br>
            Negro|L|1
          </div>

          <label for="images">Imágenes</label>
          <input
            id="images"
            type="file"
            name="images"
            accept="image/*"
            multiple
          >

          <label class="saas-checkbox" style="margin-top: 14px;">
            <input
              type="checkbox"
              name="featured"
              <%= product?.featured ? 'checked' : '' %>
            >
            <span>Mostrar como destacado en la home</span>
          </label>
        </section>
      </div>

      <% if (product?.images?.length) { %>
        <section class="saas-card saas-form-section">
          <h2>Imágenes actuales</h2>
          <div class="saas-image-grid">
            <% product.images.forEach((image) => { %>
              <img src="<%= image.image_url %>" alt="Imagen del producto">
            <% }) %>
          </div>
        </section>
      <% } %>

      <div class="saas-form-actions">
        <a href="/admin" class="saas-btn saas-btn-outline">Cancelar</a>
        <button type="submit" class="saas-btn saas-btn-primary">
          <%= product && product.id ? 'Guardar cambios' : 'Crear producto' %>
        </button>
      </div>
    </form>
  </main>
</body>
</html>