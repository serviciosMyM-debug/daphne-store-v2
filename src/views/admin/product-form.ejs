<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="saas-body">
  <div class="saas-form-page">
    <div class="saas-form-top">
      <div>
        <span class="saas-eyebrow">Gestión de catálogo</span>
        <h1><%= product ? 'Editar producto' : 'Nuevo producto' %></h1>
      </div>
      <div class="saas-top-actions">
        <a href="/admin" class="saas-btn saas-btn-outline">Volver al dashboard</a>
      </div>
    </div>

    <form
      class="saas-product-form"
      method="POST"
      action="<%= product ? `/admin/productos/${product.id}?_method=PUT` : '/admin/productos' %>"
      id="productForm"
    >
      <div class="saas-form-grid">
        <section class="saas-card saas-form-section">
          <h2>Información principal</h2>

          <label>Nombre del producto</label>
          <input type="text" name="name" required value="<%= product?.name || '' %>">

          <label>Descripción</label>
          <textarea name="description" rows="6" required><%= product?.description || '' %></textarea>

          <label>Categoría</label>
          <input type="text" name="category" required value="<%= product?.category || '' %>">

          <label>Precio</label>
          <input type="number" step="0.01" name="price" required value="<%= product?.price || '' %>">
        </section>

        <section class="saas-card saas-form-section">
          <h2>Stock, visibilidad y variantes</h2>

          <label>Estado visual</label>
          <select name="status" required>
            <option value="in_stock" <%= product?.status === 'in_stock' ? 'selected' : '' %>>En stock</option>
            <option value="sale" <%= product?.status === 'sale' ? 'selected' : '' %>>Sale</option>
            <option value="sold_out" <%= product?.status === 'sold_out' ? 'selected' : '' %>>Agotado</option>
          </select>

          <label>Variantes (una por línea)</label>
          <textarea
            name="variants_text"
            rows="8"
            placeholder="Blanco|L|2&#10;Blanco|M|2&#10;Blanco|S|2&#10;Negro|L|2&#10;Negro|M|2&#10;Negro|S|2"
          ><%= product?.variants_text || '' %></textarea>

          <p style="margin-top:10px; color:#64748b;">
            Formato: <strong>Color|Talle|Stock</strong><br>
            Ejemplo: <strong>Blanco|M|2</strong>
          </p>

          <label class="saas-checkbox">
            <input type="checkbox" name="featured" <%= product?.featured ? 'checked' : '' %>>
            Mostrar como destacado en la home
          </label>
        </section>
      </div>

      <section class="saas-card saas-form-section">
        <h2>Tabla de talles e imágenes</h2>

        <label>Tabla de talles (HTML simple)</label>
        <textarea name="size_chart_html" rows="8" placeholder="S: 50cm ancho / 70cm largo<br>M: 53cm ancho / 72cm largo"><%= product?.size_chart_html || '' %></textarea>

        <label>Imágenes seleccionadas</label>
        <textarea name="image_urls" id="imageUrlsInput" rows="8" readonly><%= product?.image_urls || '' %></textarea>

        <div class="saas-selected-images" id="selectedImages"></div>

        <div class="saas-gallery-header">
          <h3>Elegir desde galería</h3>
          <p>Hacé clic en las imágenes de <strong>public/stock</strong> para agregarlas o quitarlas.</p>
        </div>

        <div class="saas-stock-gallery">
          <% stockImages.forEach((img) => { %>
            <button
              type="button"
              class="saas-stock-image-btn"
              data-image-url="<%= img.url %>"
            >
              <img src="<%= img.url %>" alt="<%= img.file %>">
              <span><%= img.file %></span>
            </button>
          <% }) %>
        </div>

        <% if (!stockImages.length) { %>
          <p style="margin-top:12px; color:#64748b;">
            No se encontraron imágenes en <strong>public/stock</strong>.
          </p>
        <% } %>
      </section>

      <div class="saas-form-actions">
        <button class="saas-btn saas-btn-primary" type="submit">
          <%= product ? 'Guardar cambios' : 'Crear producto' %>
        </button>
        <a class="saas-btn saas-btn-outline" href="/admin">Cancelar</a>
      </div>
    </form>
  </div>

  <script>
    (function () {
      const imageUrlsInput = document.getElementById('imageUrlsInput');
      const selectedImagesContainer = document.getElementById('selectedImages');
      const stockButtons = document.querySelectorAll('.saas-stock-image-btn');

      function getSelectedImages() {
        return imageUrlsInput.value
          .split('\n')
          .map(v => v.trim())
          .filter(Boolean);
      }

      function setSelectedImages(images) {
        imageUrlsInput.value = images.join('\n');
        renderSelectedImages();
        highlightStockButtons();
      }

      function renderSelectedImages() {
        const images = getSelectedImages();
        selectedImagesContainer.innerHTML = '';

        if (!images.length) {
          selectedImagesContainer.innerHTML = '<p class="saas-no-images">No hay imágenes seleccionadas.</p>';
          return;
        }

        images.forEach((url) => {
          const card = document.createElement('div');
          card.className = 'saas-selected-image-card';

          card.innerHTML = `
            <img src="${url}" alt="Seleccionada">
            <div class="saas-selected-image-card-body">
              <span>${url}</span>
              <button type="button" class="saas-remove-image-btn">Quitar</button>
            </div>
          `;

          const removeBtn = card.querySelector('.saas-remove-image-btn');
          removeBtn.addEventListener('click', () => {
            const nextImages = getSelectedImages().filter((item) => item !== url);
            setSelectedImages(nextImages);
          });

          selectedImagesContainer.appendChild(card);
        });
      }

      function highlightStockButtons() {
        const selected = getSelectedImages();

        stockButtons.forEach((btn) => {
          const url = btn.dataset.imageUrl;
          btn.classList.toggle('active', selected.includes(url));
        });
      }

      stockButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const url = btn.dataset.imageUrl;
          const selected = getSelectedImages();

          if (selected.includes(url)) {
            setSelectedImages(selected.filter((item) => item !== url));
          } else {
            setSelectedImages([...selected, url]);
          }
        });
      });

      renderSelectedImages();
      highlightStockButtons();
    })();
  </script>
</body>
</html>