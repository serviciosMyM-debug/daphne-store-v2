<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
  <meta name="description" content="Panel administrador Daphné" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <main class="admin-shell">
    <section class="admin-page-hero">
      <div class="container admin-hero-row">
        <div>
          <span class="eyebrow">Gestión de catálogo</span>
          <h1><%= product && product.id ? 'Editar producto' : 'Nuevo producto' %></h1>
        </div>
        <a href="/admin" class="btn btn-outline">Volver al dashboard</a>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <form
          action="<%= product && product.id ? '/admin/productos/' + product.id + '?_method=PUT' : '/admin/productos' %>"
          method="POST"
          enctype="multipart/form-data"
          class="admin-product-grid"
        >
          <div class="admin-card">
            <h2>Información principal</h2>

            <label for="name">Nombre del producto</label>
            <input id="name" type="text" name="name" required value="<%= product?.name || '' %>">

            <label for="description">Descripción</label>
            <textarea id="description" name="description" rows="6" required><%= product?.description || '' %></textarea>

            <label for="category">Categoría</label>
            <input id="category" type="text" name="category" value="<%= product?.category || '' %>">

            <label for="price">Precio</label>
            <input id="price" type="number" step="0.01" min="0" name="price" required value="<%= product?.price || '' %>">

            <label for="size_chart_html">Tabla de talles / HTML opcional</label>
            <textarea id="size_chart_html" name="size_chart_html" rows="6"><%= product?.size_chart_html || '' %></textarea>
          </div>

          <div class="admin-card">
            <h2>Stock y visibilidad</h2>

            <label for="stock_preview">Stock total calculado</label>
            <input
              id="stock_preview"
              type="text"
              value="<%= product?.stock || 0 %>"
              readonly
            >

            <label for="status">Estado visual</label>
            <select id="status" name="status">
              <option value="in_stock" <%= product?.status === 'in_stock' ? 'selected' : '' %>>En stock</option>
              <option value="sold_out" <%= product?.status === 'sold_out' ? 'selected' : '' %>>Agotado</option>
              <option value="hidden" <%= product?.status === 'hidden' ? 'selected' : '' %>>Oculto</option>
            </select>

            <label for="variants_text">Variantes (una por línea)</label>
            <textarea
              id="variants_text"
              name="variants_text"
              rows="10"
              placeholder="Blanco|S|2&#10;Blanco|M|3&#10;Negro|L|1"
              required
            ><%= product?.variantsText || '' %></textarea>

            <p style="margin-top:8px; font-size:14px; opacity:.8;">
              Formato: <strong>Color|Talle|Stock</strong><br>
              Ejemplo:<br>
              Blanco|S|2<br>
              Blanco|M|3<br>
              Negro|L|1
            </p>

            <label for="images">Imágenes</label>
            <input id="images" type="file" name="images" accept="image/*" multiple>

            <label class="checkbox-row" style="display:flex;align-items:center;gap:10px;margin-top:18px;">
              <input type="checkbox" name="featured" <%= product?.featured ? 'checked' : '' %>>
              <span>Mostrar como destacado en la home</span>
            </label>
          </div>

          <% if (product?.images?.length) { %>
            <div class="admin-card" style="grid-column:1 / -1;">
              <h2>Imágenes actuales</h2>
              <div style="display:flex;flex-wrap:wrap;gap:12px;">
                <% product.images.forEach((image) => { %>
                  <img
                    src="<%= image.image_url %>"
                    alt="Imagen producto"
                    style="width:110px;height:140px;object-fit:cover;border-radius:16px;border:1px solid rgba(0,0,0,.08);"
                  >
                <% }) %>
              </div>
            </div>
          <% } %>

          <div style="grid-column:1 / -1; display:flex; gap:12px; justify-content:flex-end;">
            <a href="/admin" class="btn btn-outline">Cancelar</a>
            <button type="submit" class="btn btn-primary">
              <%= product && product.id ? 'Guardar cambios' : 'Crear producto' %>
            </button>
          </div>
        </form>
      </div>
    </section>
  </main>
</body>
</html>