<!DOCTYPE html>
<html lang="es">
<head>
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="saas-body">
  <div class="saas-form-page">
    <div class="saas-form-top">
      <div>
        <span class="saas-eyebrow">Configuración</span>
        <h1>Identidad y datos de la tienda</h1>
        <p>Desde acá el cliente puede editar los datos generales que aparecen en la web.</p>
      </div>

      <div class="saas-top-actions">
        <a href="/admin" class="saas-btn saas-btn-outline">Volver al dashboard</a>
      </div>
    </div>

    <form class="saas-product-form" method="POST" action="/admin/settings">
      <div class="saas-form-grid">
        <section class="saas-card saas-form-section">
          <h2>Datos principales</h2>

          <label>Nombre del sitio</label>
          <input type="text" name="site_name" value="<%= settings.site_name %>" required>

          <label>Dominio</label>
<input type="text" name="site_domain" value="<%= settings.site_domain %>">

<label>WhatsApp</label>
<input type="text" name="whatsapp" value="<%= settings.whatsapp %>">

<label>Email</label>
<input type="email" name="email" value="<%= settings.email %>">
        </section>

        <section class="saas-card saas-form-section">
          <h2>Encabezado principal</h2>

          <label>Título hero</label>
          <input type="text" name="hero_title" value="<%= settings.hero_title %>" required>

          <label>Subtítulo hero</label>
          <textarea name="hero_subtitle" rows="5" required><%= settings.hero_subtitle %></textarea>

          <label>Texto de envíos</label>
          <textarea name="shipping_text" rows="5" required><%= settings.shipping_text %></textarea>
        </section>
      </div>

      <section class="saas-card saas-form-section">
        <h2>Texto de marca</h2>

        <label>Descripción / sobre la marca</label>
        <textarea name="about_text" rows="6" required><%= settings.about_text %></textarea>
      </section>

      <div class="saas-form-actions">
        <button class="saas-btn saas-btn-primary" type="submit">Guardar configuración</button>
        <a class="saas-btn saas-btn-outline" href="/admin">Cancelar</a>
      </div>
    </form>
  </div>
</body>
</html>